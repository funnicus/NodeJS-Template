{
  "name": "nodejs-template",
  "version": "1.0.0",
  "description": "A Node.js template for building RESTful APIs.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production node src/index.ts",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "typecheck": "tsc",
    "test": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:debug": "vitest run --printConsoleTrace=true --silent=false && vitest run --config vitest.integration.config.ts --printConsoleTrace=true --silent=false",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate:latest": "kysely migrate:latest",
    "migrate:up": "kysely migrate:up",
    "migrate:down": "kysely migrate:down",
    "migrate:rollback": "kysely migrate:rollback",
    "migrate:list": "kysely migrate:list",
    "migrate:make": "kysely migrate:make",
    "seed": "kysely seed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "keywords": [],
  "author": "Juhana Kuparinen",
  "license": "ISC",
  "packageManager": "pnpm@11.5.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.2",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "kysely-ctl": "^0.21.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  }
}
